#Before 

exports.handler = async (event) => {
    const body = JSON.parse(event.body);

    await saveFeedback(body.message);

    return {
        statusCode: 200,
        body: JSON.stringify({ status: "ok" })
    };
};
#After

exports.handler = async (event) => {
    const auth = event.headers.authorization;

    if (!auth) {
        return {
            statusCode: 401,
            body: JSON.stringify({
                status: "err",
                msg: "unauthorized"
            })
        };
    }

    const body = JSON.parse(event.body);

    await saveFeedback(body.message);

    return {
        statusCode: 200,
        body: JSON.stringify({ status: "ok" })
    };
};
